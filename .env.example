# BehaviorIQ ML Service — Environment Variables
# Copy this file to .env and fill in the values

# Loki log push endpoint
# When running via docker compose: http://loki:3100/loki/api/v1/push
# When running locally (uvicorn only): http://localhost:3100/loki/api/v1/push
LOKI_URL=http://localhost:3100/loki/api/v1/push

# Environment label attached to every log line in Loki (e.g. hackathon, dev, prod)
APP_ENV=hackathon
